---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
---

<Layout
  title="David Umiri"
  description="David Umiri's personal portfolio showcasing web development projects and skills."
  keywords="David Umiri, web development, portfolio, projects"
>
  <main class="p-4 sm:p-8 md:p-16 mt-8 md:mt-16">
    <h1
      class="text-gray-800 dark:text-white text-3xl sm:text-4xl md:text-5xl mb-4 mt-4 sm:mb-6 md:mb-8"
    >
      Welcome!
    </h1>

    <p
      class="text-gray-700 dark:text-white text-base sm:text-lg md:text-xl mb-4 sm:mb-6 md:mb-8"
    >
      Hello! I’m David Umiri, a web developer. I combine the power of modern
      code (React, Node.js, Tailwind CSS) with the versatility of WordPress and
      Elementor to create custom digital experiences. As a graduate of DAW with
      real-world agency experience, I focus on developing clean, optimized, and
      innovative solutions. Explore my portfolio and discover what I can create!
    </p>

    <h2
      id="code-projects"
      class="scroll-mt-20 text-gray-800 dark:text-white text-2xl sm:text-3xl md:text-4xl mb-4 sm:mb-6 md:mb-8"
    >
      Code Projects
    </h2>
    <ul
      role="list"
      class="flex flex-col sm:flex-row gap-4 sm:gap-5 flex-wrap text-black"
    >
      <Card
        image="/portfolio-dauc/images/proyecto-buscar-imagenes.webp"
        title="Image Search"
        description="A dynamic web application that allows users to find high-quality images using the Unsplash API. Designed with a modern interface for a seamless experience."
        link="https://app-fotos-frontend.vercel.app/"
        technologies={["nodejs", "react", "tailwindcss", "vercel"]}
        imageLoading="eager"
        techLoading="lazy"
      />
      <Card
        image="/portfolio-dauc/images/proyecto-quasar-pomodoro-to-do.webp"
        title="Pomodoro + Task List"
        description="A one-stop productivity application that combines task management and the Pomodoro technique, built with Quasar to enhance focus and efficiency."
        link="https://quasar-to-do-pomodoro.vercel.app/#/"
        technologies={["quasar", "vue", "vercel"]}
        imageLoading="eager"
        techLoading="lazy"
      />
    </ul>

    <h2
      id="wordpress-projects"
      class="scroll-mt-20 mt-10 text-gray-800 dark:text-white text-2xl sm:text-3xl md:text-4xl mb-4 sm:mb-6 md:mb-8"
    >
      WordPress Projects
    </h2>
    <ul
      role="list"
      class="flex flex-col sm:flex-row gap-4 sm:gap-5 flex-wrap text-black"
    >
      <Card
        image="/portfolio-dauc/images/inmasan-tecnologia.webp"
        title="Inmasan Tecnología"
        description="Website developed for Inmasan Tecnología, designed to effectively showcase their technology solutions and services."
        link="https://www.inmasan.com/"
        technologies={["wordpress", "elementor"]}
        imageLoading="lazy"
        techLoading="lazy"
      />
      <Card
        image="/portfolio-dauc/images/gofastweb.webp"
        title="Go Fast Web"
        description="A fast and responsive website created for Go Fast Web, designed to effectively showcase their web development solutions."
        link="https://gofastweb.es/"
        technologies={["wordpress", "elementor"]}
        imageLoading="lazy"
        techLoading="lazy"
      />
      <Card
        image="/portfolio-dauc/images/loreabaldor.webp"
        title="Lorea Baldor"
        description="A professional website developed for Lorea Baldor, designed to showcase her work in a visually appealing and effective manner."
        link="https://loreabaldor.com/"
        technologies={["wordpress", "elementor"]}
        imageLoading="lazy"
        techLoading="lazy"
      />
    </ul>
  </main>
</Layout>
